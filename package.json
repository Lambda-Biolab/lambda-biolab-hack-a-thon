{
  "name": "lambda-hack-scaffold",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#out\" \"#.next\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\" \"#out\" \"#.next\"",
    "lint:links": "lychee --config lychee.toml --no-progress \"**/*.md\"",
    "optimize:photos": "node scripts/optimize-photos.mjs",
    "generate:og": "node scripts/generate-og.mjs",
    "verify:build": "node scripts/verify-build.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "markdownlint-cli2": "^0.22.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
